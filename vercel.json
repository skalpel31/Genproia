{
  "version": 2,
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/api/demo",
      "dest": "/api/demo.js"
    },
    {
      "src": "/api/email-welcome",
      "dest": "/api/email-welcome.js"
    },
    {
      "src": "/api/chat-dashboard",
      "dest": "/api/chat-dashboard.js"
    },
    {
      "src": "/api/chat-public",
      "dest": "/api/chat-public.js"
    },
    {
      "src": "/api/deploy",
      "dest": "/api/deploy.js"
    },
    {
      "src": "/api/generate-logo",
      "dest": "/api/generate-logo.js"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.json)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.svg)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/$1"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
